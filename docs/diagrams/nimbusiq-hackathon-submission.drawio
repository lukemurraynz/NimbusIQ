        <mxCell id="dep_nsp_label" value="&lt;b&gt;Zero-Secrets Architecture:&lt;/b&gt; All service-to-service auth uses Managed Identity. NSP enforces network boundaries for PaaS resources." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#C62828;fontStyle=2;" vertex="1" parent="dep_1">
