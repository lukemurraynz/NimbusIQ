    <!-- Added to support NpgsqlDataSourceBuilder used in Program.cs -->
    <PackageReference Include="Npgsql" Version="10.0.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Application\Atlas.ControlPlane.Application.csproj" />
    <ProjectReference Include="..\Infrastructure\Atlas.ControlPlane.Infrastructure.csproj" />
    <ProjectReference Include="..\..\..\..\packages\contracts\api\Atlas.Contracts.Api\Atlas.Contracts.Api.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="NJsonSchema" Version="11.5.2" />
  </ItemGroup>

